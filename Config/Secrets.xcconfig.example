// 이 파일을 `Secrets.xcconfig`로 복사한 뒤 InsForge 대시보드에서 발급받은 키를 채운다.
// 실제 `Secrets.xcconfig`는 .gitignore에 들어가 커밋되지 않는다.
//
// 발급 위치: https://insforge.dev/dashboard/project/<project-id>/settings/api-keys

INSFORGE_API_KEY = ik_REPLACE_WITH_YOUR_INSFORGE_ANON_KEY

// 번들 ID 프리픽스. OAuth(Apple/Google/Kakao) 등록 번들과 일치해야 하므로 팀 공용 값으로 고정한다.
// 비워두면 PRODUCT_BUNDLE_IDENTIFIER가 깨지므로 반드시 값이 있어야 한다.
ODODOK_BUNDLE_PREFIX = com.shamrock

// === ODO-47 OAuth 소셜 로그인 ===
// Google: Google Cloud Console의 iOS OAuth client id + 그 reversed 형태(URL scheme용).
GOOGLE_CLIENT_ID = REPLACE.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.REPLACE
// Kakao: 네이티브 앱키(SDK init + URL scheme kakao{앱키}).
KAKAO_NATIVE_APP_KEY = REPLACE_KAKAO_NATIVE_APP_KEY

// === ODO-78 Sentry 크래시·에러 모니터링 ===
// Sentry 대시보드 → Settings → Projects → [프로젝트] → Client Keys (DSN)에서 발급.
// 주의: 'https://'를 빼고 본문만 적는다(xcconfig가 '//'를 주석 처리하므로).
// 예: <id>@<org>.ingest.<region>.sentry.io/<project>
SENTRY_DSN = REPLACE_WITH_SENTRY_DSN_BODY_WITHOUT_HTTPS

// === ODO-79 Amplitude 제품·리텐션 분석 ===
// Amplitude 대시보드 → Settings → Projects → [프로젝트] → API Key(레거시 API 키)에서 발급.
// 프로젝트가 EU 리전이면 코드(AmplitudeProvider)가 serverZone=.EU로 전송한다.
AMPLITUDE_API_KEY = REPLACE_WITH_AMPLITUDE_API_KEY

// === ODO-80 Firebase Analytics ===
// Firebase는 키를 xcconfig가 아니라 GoogleService-Info.plist로 받는다.
// Firebase 콘솔 → 프로젝트 설정 → iOS 앱(com.sungho.dev.ododok) → GoogleService-Info.plist 다운로드 →
// `ChewChewIOS/GoogleService-Info.plist`에 둔다. 이 파일은 .gitignore라 커밋되지 않으며,
// 없으면 Firebase는 자동 비활성(앱은 정상 동작, Amplitude만 전송).

// === ODO-78 Sentry dSYM 업로드(Release 아카이브 크래시 스택 자동 심볼화) ===
// Release 아카이브 시 project.yml의 빌드 페이즈가 dSYM을 Sentry로 올려, 크래시 스택을
// 메모리 주소가 아닌 함수명·라인으로 해독되게 한다. 미설정이면 빌드 페이즈가 조용히 skip된다.
// 자동 업로드는 sentry-cli 설치 필요(1회): brew install getsentry/tools/sentry-cli
//
// AUTH_TOKEN: Sentry → Settings → Auth Tokens에서 발급. scope에 project:releases 포함.
//   주의: 이 토큰은 Info.plist로 가지 않고 빌드 시점에만 쓰인다(앱 번들에 실리지 않음).
// ORG/PROJECT: Sentry 프로젝트 URL의 슬러그(sentry.io/organizations/<ORG>/projects/<PROJECT>).
SENTRY_AUTH_TOKEN = REPLACE_WITH_SENTRY_AUTH_TOKEN
SENTRY_ORG = REPLACE_WITH_SENTRY_ORG_SLUG
SENTRY_PROJECT = REPLACE_WITH_SENTRY_PROJECT_SLUG
