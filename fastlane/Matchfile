# fastlane match — 인증서·프로비저닝 프로파일을 별도 프라이빗 git 레포에 암호화 저장한다.
# 프로파일 이름은 Project.swift의 PROVISIONING_PROFILE_SPECIFIER("match AppStore ..." / "match Development ...")와
# 정확히 일치해야 한다(match가 만드는 프로파일 이름 규칙 = "match <Type> <bundleId>").

git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")

# 최초 생성 시 기본 타입. CI에서는 lane에서 type: "appstore"로 명시 호출한다.
type("development")

# 앱 + 확장 2개 모두 프로파일이 필요하다.
app_identifier([
  "com.shamrock.ododok",
  "com.shamrock.ododok.OdodokWidgets",
  "com.shamrock.ododok.OdodokNotificationContent",
])

team_id("26SRR6SP9B")

# CI 러너에서는 항상 readonly로 동작(인증서를 새로 만들지 않고 내려받아 설치만).
# 인증서 생성/갱신은 사람이 로컬에서 1회 수행한다.
readonly(ENV["CI"] == "true")
