default_platform(:ios)

require_relative "versioning"

WORKSPACE = "ChewChewIOS.xcworkspace"
SCHEME = "ChewChewIOS"
VERSION_CONFIG = "Config/Version.xcconfig"

APP_ID = "com.shamrock.ododok"
WIDGETS_ID = "com.shamrock.ododok.OdodokWidgets"
NOTIF_ID = "com.shamrock.ododok.OdodokNotificationContent"
ALL_APP_IDS = [APP_ID, WIDGETS_ID, NOTIF_ID].freeze

# Project.swift가 Manual 서명 + 아래 이름의 프로파일을 참조한다.
# export 단계에서 번들ID → 프로파일 이름 매핑을 명시해 준다.
APPSTORE_PROFILES = {
  APP_ID => "match AppStore #{APP_ID}",
  WIDGETS_ID => "match AppStore #{WIDGETS_ID}",
  NOTIF_ID => "match AppStore #{NOTIF_ID}",
}.freeze

def asc_api_key
  # ASC_KEY_P8는 .p8 원문을 base64로 인코딩한 값(GitHub Secret).
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8"),
    is_key_content_base64: true,
    in_house: false
  )
end

# App Store용 아카이브를 만들어 .ipa 경로를 돌려준다.
# 빌드/마케팅 버전은 xcodeproj를 수정하지 않고 xcargs로 주입한다(Tuist 생성 프로젝트라 매번 재생성됨).
def build_appstore_ipa(build_number:, marketing_version: nil)
  xcargs = ["CURRENT_PROJECT_VERSION=#{build_number}"]
  xcargs << "MARKETING_VERSION=#{marketing_version}" if marketing_version

  build_app(
    workspace: WORKSPACE,
    scheme: SCHEME,
    configuration: "Release",
    clean: true,
    export_method: "app-store",
    xcargs: xcargs.join(" "),
    export_options: {
      provisioningProfiles: APPSTORE_PROFILES,
      signingStyle: "manual",
    },
    output_directory: "build/ipa",
    buildlog_path: "build/fastlane-logs"
  )
end

# TestFlight에 올라간 가장 큰 빌드 번호 + 1을 돌려준다.
# 빌드가 하나도 없으면 1부터 시작한다.
def next_build_number(api_key)
  latest = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: APP_ID,
    initial_build_number: 0
  )
  (latest + 1).to_s
end

def live_marketing_version(api_key)
  app_store_build_number(
    api_key: api_key,
    app_identifier: APP_ID,
    live: true,
    initial_build_number: 0
  )
  lane_context[SharedValues::LATEST_VERSION]
rescue => error
  UI.important("App Store live version 확인 실패 - repo MARKETING_VERSION 사용: #{error.message}")
  nil
end

def next_beta_marketing_version(api_key)
  repo_version = OdodokVersioning.read_marketing_version(VERSION_CONFIG)
  live_version = live_marketing_version(api_key)
  marketing_version = OdodokVersioning.next_marketing_version(repo_version, live_version)

  UI.message("Resolved TestFlight marketing version: #{marketing_version} (repo: #{repo_version}, live: #{live_version || "none"})")
  marketing_version
end

platform :ios do
  before_all do
    # CI에서 임시 keychain을 만들어 match가 인증서를 안전하게 설치하도록 한다.
    setup_ci if ENV["CI"] == "true"
  end

  desc "TestFlight 배포 (main 머지 시 자동)"
  lane :beta do
    api_key = asc_api_key

    match(
      type: "appstore",
      app_identifier: ALL_APP_IDS,
      api_key: api_key,
      readonly: true
    )

    # 빌드 번호는 TestFlight에 이미 올라간 최신 번호 + 1로 자동 계산한다.
    # App Store는 새 빌드가 항상 이전보다 커야 하므로 고정값/run number는 충돌할 수 있다.
    build_number = next_build_number(api_key)
    marketing_version = next_beta_marketing_version(api_key)

    build_appstore_ipa(build_number: build_number, marketing_version: marketing_version)

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      # 내부 테스터에게만 자동 배포. 외부 그룹/심사는 App Store Connect에서 관리.
      distribute_external: false
    )
  end

  desc "App Store 심사 제출 (vX.Y.Z 태그 시 자동, 최종 출시는 수동)"
  lane :release do
    api_key = asc_api_key

    # 워크플로우가 태그 vX.Y.Z에서 'v'를 떼어 APP_VERSION으로 넘긴다.
    marketing_version = ENV.fetch("APP_VERSION")
    build_number = next_build_number(api_key)

    match(
      type: "appstore",
      app_identifier: ALL_APP_IDS,
      api_key: api_key,
      readonly: true
    )

    build_appstore_ipa(build_number: build_number, marketing_version: marketing_version)

    upload_to_app_store(
      api_key: api_key,
      app_version: marketing_version,
      submit_for_review: true,     # 심사 제출까지
      automatic_release: false,    # 심사 통과 후 '출시' 버튼은 사람이 누른다
      force: true,                 # HTML 미리보기 생략(비대화형)
      precheck_include_in_app_purchases: false,
      skip_metadata: true,         # 메타데이터/스크린샷은 App Store Connect에서 관리
      skip_screenshots: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
